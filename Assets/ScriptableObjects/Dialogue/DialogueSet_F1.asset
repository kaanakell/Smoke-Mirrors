  m_Script: {fileID: 11500000, guid: c9f02430c91bfa74cb94cc69190b898e, type: 3}
  m_Name: DialogueSet_F1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSet
  lines:
  - speaker: S<glitch>Son</glitch>
    text: Hey, <glitch>Father</glitch> . The competition just ended, you missed it.
      Again.
  - speaker: <glitch>Father</glitch>
    text: What, no?? It was next week?!
  - speaker: <glitch>Son</glitch>
    text: Yeah, last week. You need to start using a calendar, old man.
  - speaker: <glitch>Father</glitch>
    text: I suppose time passes by faster when you're older...
  - speaker: S<glitch>Son</glitch>
    text: I won 2nd place, by the way. Mom already put the painting up in the bathroom.
