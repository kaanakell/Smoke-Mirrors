  m_Script: {fileID: 11500000, guid: c9f02430c91bfa74cb94cc69190b898e, type: 3}
  m_Name: DialogueSet_F2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSet
  lines:
  - speaker: Father
    text: I think it's time for dinner. I should get home...
  - speaker: Father
    text: Excuse me, I must get to my house. Where is it?
  - speaker: Son
    text: This is your house, dad. You are home.
  - speaker: Father
    text: No, I-... My wife is at home. I think I need to search for her.
  - speaker: Son
    text: .....
  - speaker: Son
    text: Hey, why don't we play cards until she comes? She told me she will be a
      bit late tonight.
  - speaker: Father
    text: Am I okay?
  - speaker: Father
    text: Yeah! Yeah, dad, you are okay...
